{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run LSP generator",
            "type": "dart",
            "request": "launch",
            "program": "bin/generate.dart",
            "cwd": "${workspaceFolder}/old_packages/generator/",
            "args": []
        },
        {
            "name": "Run LSP Server",
            "type": "dart",
            "request": "launch",
            "program": "${workspaceFolder}/old_packages/lsp_protocol/example/server.dart",
            "args": [],
            "cwd": "${workspaceFolder}/old_packages/lsp_protocol"
        },
        {
            "name": "Run LSP Extension",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/old_packages/lsp_server_ext"
            ],
            "outFiles": [
                "${workspaceFolder}/old_packages/lsp_server_ext/out/**/*.js"
            ]
        }
    ]
}