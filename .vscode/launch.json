{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Generate",
            "request": "launch",
            "program": "bin/lsp_generator.dart",
            "type": "dart",
            "console": "terminal",
            "cwd": "${workspaceFolder}/packages/lsp_generator",
            "args": [
                "generate",
                "--verbose",
            ]
        },
        {
            // Run the LSP test server standalone for debugging.
            // Set breakpoints in any action or server_runner.dart and hit F5.
            "name": "Run LSP Server",
            "type": "dart",
            "request": "launch",
            "program": "${workspaceFolder}/packages/lsp_test_server/bin/lsp_test_server.dart",
            "cwd": "${workspaceFolder}/packages/lsp_test_server",
            "console": "terminal"
        },
        {
            // Run the VS Code extension in a new Extension Development Host window.
            // The extension will start the LSP server automatically via `dart run`.
            "name": "Run LSP Extension",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/vscode-lsp-tester"
            ],
            "outFiles": [
                "${workspaceFolder}/vscode-lsp-tester/out/**/*.js"
            ],
            "preLaunchTask": "npm: compile - vscode-lsp-tester"
        }
    ]
}