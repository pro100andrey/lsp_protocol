{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Generate",
            "request": "launch",
            "program": "${workspaceFolder}/packages/lsp_generator/bin/lsp_generator.dart",
            "type": "dart",
            "console": "terminal",
            "cwd": "${workspaceFolder}/packages/lsp_generator",
            "args": [
                "generate",
                "--verbose"
            ]
        },
        {
            "name": "Run LSP Server",
            "type": "dart",
            "request": "launch",
            "program": "${workspaceFolder}/debug/lsp_test_server/bin/lsp_test_server.dart",
            "cwd": "${workspaceFolder}/debug/lsp_test_server",
            "console": "terminal",
            "args": [
                "--socket",
                "2087"
            ]
        },
        {
            "name": "Run LSP Extension",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/debug/vscode-lsp-tester"
            ],
            "outFiles": [
                "${workspaceFolder}/debug/vscode-lsp-tester/out/**/*.js"
            ],
            "preLaunchTask": "npm: compile - vscode-lsp-tester"
        }
    ]
}
